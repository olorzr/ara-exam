# Supabase 설정
# Supabase 프로젝트 대시보드 > Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# 네이버 웍스 (LINE WORKS) OAuth
# LINE WORKS Developer Console에서 앱 등록 후 발급
NAVER_WORKS_CLIENT_ID=your-client-id-here
NAVER_WORKS_CLIENT_SECRET=your-client-secret-here

# 앱 origin (프로덕션 필수)
# OAuth redirect_uri 와 콜백 리다이렉트 URL 을 Host 헤더가 아닌 이 고정값으로 만든다.
# Host 헤더 조작으로 인한 redirect_uri 오염 / 매직링크 토큰 유출을 막는다.
# 로컬 개발(NODE_ENV != production)에서만 미설정 시 요청 origin 으로 폴백하므로 비워도 된다.
# 프로덕션에서는 필수 — 미설정이거나 잘못된 값(스킴 누락 등)이면 OAuth 라우트가 500 을 반환한다.
APP_ORIGIN=https://your-app-domain.example.com
